# WhatsApp Backend Environment Variables
# Copy this file to .env and fill in your values

# ── WhatsApp Business API ──────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=my_test_token          # Change in production

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Internal port config ──────────────────────────────────────────────────────
PORT=3000                   # This server (Node.js)
PYTHON_BRIDGE_PORT=8001     # Python audio bridge WebSocket port
PYTHON_HTTP_PORT=9001       # Python audio bridge HTTP (registration) port

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=                      # Set to 1 to enable debug logging
